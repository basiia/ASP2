@using UniDesk.Web.DTOs
@model List<TicketListDto>

    <h1>Lista zgłoszeń</h1>

    <h3>Dodaj zgłoszenie</h3>

    <form method="post" asp-action="Create">

        <div asp-validation-summary="All" style="color:red"></div>

        <div>
            <label>Tytuł</label>
            <input type="text" name="Title" />
        </div>

        <div>
            <label>Opis</label>
            <input type="text" name="Description" />
        </div>

        <button type="submit">Dodaj</button>

    </form>

    <hr>

    <h3>Filtruj zgłoszenia</h3>

    <form method="get">
        <input type="text" name="status" placeholder="Status (Open/InProgress/Closed)" />
        <button type="submit">Filtruj</button>
    </form>

    <hr>

    <ul>
        @foreach (var ticket in Model)
{
        <li>
            <!-- 🔥 ВОТ ГЛАВНОЕ ИСПРАВЛЕНИЕ -->
            <a asp-action="Details" asp-route-id="@ticket.Id">
                <strong>@ticket.Title</strong>
            </a>
            -

            @if (ticket.Status == "Open")
        {
            <span style="color:green">@ticket.Status</span>
        }
        else if (ticket.Status == "InProgress")
        {
            <span style="color:orange">@ticket.Status</span>
        }
        else if (ticket.Status == "Closed")
        {
            <span style="color:gray">@ticket.Status</span>
        }
        </li>
}
    </ul>

    <hr>

    <h3>Stronicowanie</h3>

    <a href="?page=1">1</a>
    <a href="?page=2">2</a>
    <a href="?page=3">3</a>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
